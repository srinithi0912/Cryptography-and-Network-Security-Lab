<!DOCTYPE html>
<html>
<head>
    <title>AES-128 Implementation with Intermediate Steps</title>
    <style>
        body { font-family: 'Courier New', Courier, monospace; padding: 20px; background-color: #f4f4f9; }
        .container { max-width: 900px; margin: auto; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.1);     }
        input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
        button { padding: 10px 20px; cursor: pointer; border: none; border-radius: 4px; background: #007bff; color: white; font-weight: bold; }
        button:hover { background: #0056b3; }
        .output { background: #272822; color: white; padding: 15px; margin-top: 20px; border-radius: 5px; white-space: pre-wrap; font-size: 0.85em; max-height: 500px; overflow-y: auto; }
        .round-header { color: #a6e22e; font-weight: bold; border-bottom: 1px solid #555; display: block; margin-top: 10px; }
    </style>
</head>
<body>

<div class="container">
    <h2>AES-128 Encryption & Decryption</h2>

    <label>Input (32 Hex Characters):</label>
    <input type="text" id="inputText" value="6bc1bee22e409f96e93d7e117393172a">

    <label>Key (32 Hex Characters):</label>
    <input type="text" id="key" value="2b7e151628aed2a6abf7158809cf4f3c">

    <button onclick="processAES(true)">Encrypt</button>
    <button onclick="processAES(false)">Decrypt</button>

    <div class="output" id="result"></div>
</div>

<script>
// ================= TABLES & CONSTANTS =================
const sbox = [0x63, 0x7c, 0x77, 0x7b, 0xf2, 0x6b, 0x6f, 0xc5, 0x30, 0x01, 0x67, 0x2b, 0xfe, 0xd7, 0xab, 0x76, 0xca, 0x82, 0xc9, 0x7d, 0xfa, 0x59, 0x47, 0xf0, 0xad, 0xd4, 0xa2, 0xaf, 0x9c, 0xa4, 0x72, 0xc0, 0xb7, 0xfd, 0x93, 0x26, 0x36, 0x3f, 0xf7, 0xcc, 0x34, 0xa5, 0xe5, 0xf1, 0x71, 0xd8, 0x31, 0x15, 0x04, 0xc7, 0x23, 0xc3, 0x18, 0x96, 0x05, 0x9a, 0x07, 0x12, 0x80, 0xe2, 0xeb, 0x27, 0xb2, 0x75, 0x09, 0x83, 0x2c, 0x1a, 0x1b, 0x6e, 0x5a, 0xa0, 0x52, 0x3b, 0xd6, 0xb3, 0x29, 0xe3, 0x2f, 0x84, 0x53, 0xd1, 0x00, 0xed, 0x20, 0xfc, 0xb1, 0x5b, 0x6a, 0xcb, 0xbe, 0x39, 0x4a, 0x4c, 0x58, 0xcf, 0xd0, 0xef, 0xaa, 0xfb, 0x43, 0x4d, 0x33, 0x85, 0x45, 0xf9, 0x02, 0x7f, 0x50, 0x3c, 0x9f, 0xa8, 0x51, 0xa3, 0x40, 0x8f, 0x92, 0x9d, 0x38, 0xf5, 0xbc, 0xb6, 0xda, 0x21, 0x10, 0xff, 0xf3, 0xd2, 0xcd, 0x0c, 0x13, 0xec, 0x5f, 0x97, 0x44, 0x17, 0xc4, 0xa7, 0x7e, 0x3d, 0x64, 0x5d, 0x19, 0x73, 0x60, 0x81, 0x4f, 0xdc, 0x22, 0x2a, 0x90, 0x88, 0x46, 0xee, 0xb8, 0x14, 0xde, 0x5e, 0x0b, 0xdb, 0xe0, 0x32, 0x3a, 0x0a, 0x49, 0x06, 0x24, 0x5c, 0xc2, 0xd3, 0xac, 0x62, 0x91, 0x95, 0xe4, 0x79, 0xe7, 0xc8, 0x37, 0x6d, 0x8d, 0xd5, 0x4e, 0xa9, 0x6c, 0x56, 0xf4, 0xea, 0x65, 0x7a, 0xae, 0x08, 0xba, 0x78, 0x25, 0x2e, 0x1c, 0xa6, 0xb4, 0xc6, 0xe8, 0xdd, 0x74, 0x1f, 0x4b, 0xbd, 0x8b, 0x8a, 0x70, 0x3e, 0xb5, 0x66, 0x48, 0x03, 0xf6, 0x0e, 0x61, 0x35, 0x57, 0xb9, 0x86, 0xc1, 0x1d, 0x9e, 0xe1, 0xf8, 0x98, 0x11, 0x69, 0xd9, 0x8e, 0x94, 0x9b, 0x1e, 0x87, 0xe9, 0xce, 0x55, 0x28, 0xdf, 0x8c, 0xa1, 0x89, 0x0d, 0xbf, 0xe6, 0x42, 0x68, 0x41, 0x99, 0x2d, 0x0f, 0xb0, 0x54, 0xbb, 0x16];
const invSbox = new Array(256);
for (let i = 0; i < 256; i++) invSbox[sbox[i]] = i;
const rcon = [0x01, 0x02, 0x04, 0x08, 0x10, 0x20, 0x40, 0x80, 0x1B, 0x36];

// ================= HELPERS =================
const hexToBytes = h => h.match(/.{1,2}/g).map(b => parseInt(b, 16));
const bytesToHex = b => b.map(x => x.toString(16).padStart(2, '0')).join('');
const xtime = a => ((a << 1) ^ (((a >> 7) & 1) * 0x1b)) & 0xff;
const mul = (a, b) => {
    let res = 0;
    while (b) { if (b & 1) res ^= a; a = xtime(a); b >>= 1; }
    return res;
};

// ================= AES OPERATIONS =================
function addRoundKey(state, key) { for (let i = 0; i < 16; i++) state[i] ^= key[i]; }
function subBytes(state, box) { for (let i = 0; i < 16; i++) state[i] = box[state[i]]; }

function shiftRows(s, inv = false) {
    let t = [...s];
    const offsets = inv ? [0, 13, 10, 7, 4, 1, 14, 11, 8, 5, 2, 15, 12, 9, 6, 3] : [0, 5, 10, 15, 4, 9, 14, 3, 8, 13, 2, 7, 12, 1, 6, 11];
    for (let i = 0; i < 16; i++) s[i] = t[offsets[i]];
}

function mixColumns(s, inv = false) {
    for (let i = 0; i < 4; i++) {
        let c = i * 4, a = s.slice(c, c + 4);
        if (!inv) {
            s[c]   = mul(a[0],2) ^ mul(a[1],3) ^ a[2] ^ a[3];
            s[c+1] = a[0] ^ mul(a[1],2) ^ mul(a[2],3) ^ a[3];
            s[c+2] = a[0] ^ a[1] ^ mul(a[2],2) ^ mul(a[3],3);
            s[c+3] = mul(a[0],3) ^ a[1] ^ a[2] ^ mul(a[3],2);
        } else {
            s[c]   = mul(a[0],14) ^ mul(a[1],11) ^ mul(a[2],13) ^ mul(a[3],9);
            s[c+1] = mul(a[0],9) ^ mul(a[1],14) ^ mul(a[2],11) ^ mul(a[3],13);
            s[c+2] = mul(a[0],13) ^ mul(a[1],9) ^ mul(a[2],14) ^ mul(a[3],11);
            s[c+3] = mul(a[0],11) ^ mul(a[1],13) ^ mul(a[2],9) ^ mul(a[3],14);
        }
    }
}

function keyExpansion(key) {
    let w = [...key];
    for (let i = 4; i < 44; i++) {
        let temp = w.slice((i - 1) * 4, i * 4);
        if (i % 4 === 0) {
            temp.push(temp.shift());
            temp = temp.map(b => sbox[b]);
            temp[0] ^= rcon[(i / 4) - 1];
        }
        for (let j = 0; j < 4; j++) w[i * 4 + j] = w[(i - 4) * 4 + j] ^ temp[j];
    }
    return w;
}

// ================= MAIN LOGIC =================
function processAES(encrypt) {
    const input = document.getElementById("inputText").value;
    const keyStr = document.getElementById("key").value;
    let state = hexToBytes(input), roundKeys = keyExpansion(hexToBytes(keyStr));
    let log = `<span class="round-header">--- INITIAL STATE ---</span>\nInput: ${input}\nKey:   ${keyStr}\n\n`;

    if (encrypt) {
        addRoundKey(state, roundKeys.slice(0, 16));
        log += `Whitening: ${bytesToHex(state)}\n`;
        for (let r = 1; r <= 10; r++) {
            log += `<span class="round-header">ROUND ${r}</span>\n`;
            subBytes(state, sbox); log += `SubBytes:   ${bytesToHex(state)}\n`;
            shiftRows(state);      log += `ShiftRows:  ${bytesToHex(state)}\n`;
            if (r < 10) { mixColumns(state); log += `MixColumns: ${bytesToHex(state)}\n`; }
            addRoundKey(state, roundKeys.slice(r * 16, (r + 1) * 16));
            log += `Round Key:  ${bytesToHex(roundKeys.slice(r * 16, (r + 1) * 16))}\n`;
            log += `Result:     ${bytesToHex(state)}\n`;
        }
    } else {
        addRoundKey(state, roundKeys.slice(160, 176));
        log += `Initial Key: ${bytesToHex(state)}\n`;
        for (let r = 9; r >= 0; r--) {
            log += `<span class="round-header">INV ROUND ${10 - r}</span>\n`;
            shiftRows(state, true);   log += `InvShift:   ${bytesToHex(state)}\n`;
            subBytes(state, invSbox); log += `InvSub:     ${bytesToHex(state)}\n`;
            addRoundKey(state, roundKeys.slice(r * 16, (r + 1) * 16));
            log += `Round Key:  ${bytesToHex(roundKeys.slice(r * 16, (r + 1) * 16))}\n`;
            if (r > 0) { mixColumns(state, true); log += `InvMix:     ${bytesToHex(state)}\n`; }
            log += `Result:     ${bytesToHex(state)}\n`;
        }
    }
    document.getElementById("result").innerHTML = log + `\n<span class="round-header">FINAL OUTPUT: ${bytesToHex(state)}</span>`;
}
</script>
</body>
</html>
